# ──────────────────────────────────
# 小圆的 dotfiles 仓库 — 默认忽略所有，只追踪指定文件
# 这是用户目录级 Git 仓库的标准做法
# ──────────────────────────────────

# 1. 默认忽略一切
*

# 2. 白名单：允许追踪的目录/文件（逐级放行）
# .claude 核心配置
!.claude/
.claude/*
!.claude/keybindings.json
!.claude/CLAUDE.md
# ⚠️ 安全：以下文件含明文 API key / token，绝不追踪
#   .claude.json（账户配置）
#   .claude/settings.json（含 DeepSeek/Anthropic key）
#   .claude/settings.local.json（含 GitHub token ghp_）

# .claude 子目录 — 只放行手动编写的脚本和 memory
!.claude/projects/
.claude/projects/*
!.claude/projects/C--Users-Administrator/
.claude/projects/C--Users-Administrator/*
!.claude/projects/C--Users-Administrator/memory/
.claude/projects/C--Users-Administrator/memory/*
!.claude/projects/C--Users-Administrator/memory/*.md

# .claude 自定义技能
!.claude/skills/
.claude/skills/*
!.claude/skills/*/
.claude/skills/*/*
!.claude/skills/*/SKILL.md

# .claude 自定义脚本
!.claude/clauditor_cn.py
!.claude/ocr_screenshot.py
!.claude/create_new_xiaoyuan.ps1
!.claude/vision_bridge.py
!.claude/switch_model.py
!.claude/auto_ask_model.py
# ⚠️ deepseek_config.json 含 key，绝不追踪

# .claude 切换模型 bat
!.claude/切回DeepSeek.bat
!.claude/切回Claude订阅.bat

# VS Code 使用技巧
!.claude/vscode使用技巧.md

# .clauditor 配置
!.clauditor/
.clauditor/*
!.clauditor/config.json

# .gitignore 自身
!.gitignore

# ──────────────────────────────────
# 注意：新增文件需要手动追加白名单规则
# ──────────────────────────────────
